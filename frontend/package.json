{
  "name": "alignix",
  "version": "1.0.0",
  "type": "module",
  "description": "Autonomous Document Formatting Intelligence Platform",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run electron:dev\" \"npm run react:dev\"",
    "react:dev": "vite --port 3000",
    "electron:dev": "wait-on http://localhost:3000 && electron .",
    "build": "vite build && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "zustand": "^4.5.2",
    "socket.io-client": "^4.7.5",
    "axios": "^1.7.2",
    "recharts": "^2.12.7",
    "lucide-react": "^0.395.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.alignix.app",
    "productName": "Alignix",
    "directories": { "output": "dist-electron" },
    "files": ["electron/**/*", "dist/**/*"],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "extraResources": [
      { "from": "../backend", "to": "backend", "filter": ["**/*"] }
    ]
  }
}
